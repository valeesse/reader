{
  "name": "zenith-reader",
  "private": true,
  "version": "1.1.0",
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/fast-tauri-dev.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "server:dev": "cargo run -p zenith-reader-server",
    "docker:up": "docker compose up --build",
    "build": "tsc --noEmit && vite build",
    "test:unit": "node --test scripts/metadata-series.test.mjs",
    "test:reader:real": "node scripts/reader-real-scenario.mjs",
    "vendor:react": "rimraf src/vendor/prebuilt-react && esbuild scripts/vendor/react.mjs scripts/vendor/react-jsx-runtime.mjs scripts/vendor/react-jsx-dev-runtime.mjs scripts/vendor/react-dom-client.mjs --bundle --splitting --minify --format=esm --platform=browser --outdir=src/vendor/prebuilt-react --chunk-names=shared/[name]-[hash] --define:process.env.NODE_ENV=\\\"development\\\"",
    "preview": "vite preview",
    "clean": "rimraf dist src-tauri/target",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "idb-keyval": "^6.2.6",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.2"
  }
}
