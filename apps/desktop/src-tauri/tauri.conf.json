{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zenith Reader",
  "version": "1.1.0",
  "identifier": "com.zenith.reader",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../../../target/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zenith Reader",
        "width": 1180,
        "height": 780,
        "minWidth": 390,
        "minHeight": 700,
        "visible": false,
        "transparent": false,
        "backgroundColor": "#F2F2F7",
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost blob: data:; font-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; frame-src 'self' blob: data:; object-src 'none'; base-uri 'none'; form-action 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/reader-core/**", "$APPCACHE/reader-fonts/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": ["epub"],
        "name": "Zenith Reader EPUB",
        "description": "EPUB eBook",
        "mimeType": "application/epub+zip",
        "contentTypes": ["org.idpf.epub-container"],
        "role": "Viewer",
        "rank": "Alternate"
      },
      {
        "ext": ["txt"],
        "name": "Zenith Reader TXT",
        "description": "Text Document",
        "mimeType": "text/plain",
        "contentTypes": ["public.plain-text"],
        "role": "Viewer",
        "rank": "Alternate"
      }
    ],
    "icon": ["icons/icon.ico", "icons/icon.icns"]
  }
}
