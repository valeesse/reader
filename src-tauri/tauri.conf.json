{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zenith Reader",
  "version": "0.1.0",
  "identifier": "com.zenith.reader",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zenith Reader",
        "width": 1180,
        "height": 780,
        "minWidth": 390,
        "minHeight": 700,
        "visible": false,
        "transparent": false,
        "backgroundColor": "#F2F2F7",
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": ["icons/icon.ico", "icons/icon.icns"]
  }
}
